# Copy to .env for local development. Real .env is git-ignored and must never
# be committed. All variables are optional; sane defaults apply.

# Where translation defaults live (relative paths resolve against backend/).
# TRANSLATOR_CONFIG_PATH=config/defaults.yaml

# Provider endpoint and attribution headers (HTTP-Referer / X-Title).
# TRANSLATOR_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# TRANSLATOR_OPENROUTER_REFERER=https://your-app.example
# TRANSLATOR_OPENROUTER_TITLE=simple-byok-translator
# TRANSLATOR_REQUEST_TIMEOUT=60

# LOCAL DEV ONLY: fallback OpenRouter key used when a request omits one.
# Prefer the OS keyring over a plaintext key here (encrypted at rest):
#   uv run python -c "import keyring; keyring.set_password('byok-translator','openrouter', input('key: '))"
# Resolution order: this env var -> OS keyring -> none. Leave unset in
# production — production is bring-your-own-key per request.
# TRANSLATOR_DEV_API_KEY=sk-or-...
# TRANSLATOR_USE_KEYRING=true
# TRANSLATOR_KEYRING_SERVICE=byok-translator
# TRANSLATOR_KEYRING_ACCOUNT=openrouter

# Comma-separated CORS origins for the future React frontend dev server.
# TRANSLATOR_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
